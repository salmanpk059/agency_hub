# Gemini API Key (optional - for AI features)
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=your_gemini_api_key_here

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL=your_app_url_here

# Supabase Configuration
# Paste values from Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_anon_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_publishable_anon_key_here

# Server-side service role key (bypasses RLS for API routes)
# Dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Security Passphrase for Owner Login (REQUIRED)
OWNER_PASSPHRASE=generate_a_strong_random_passphrase_here

# Master Owner Email for agency admin access
MASTER_OWNER_EMAIL=your_owner_email@example.com

# Security Passphrase for Client Login (if applicable)
CLIENT_SECURITY_PASSPHRASE=generate_a_strong_random_passphrase_here

# Server Port
PORT=3001
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase — paste from Dashboard → Settings → API
VITE_SUPABASE_URL="https://chfivlsfupwgdxohwhwz.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_3d2lYyt_loOHXkoDY8CA_A__wzgI8hh"
SUPABASE_URL="https://chfivlsfupwgdxohwhwz.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_3d2lYyt_loOHXkoDY8CA_A__wzgI8hh"

# Required for server API routes (Dashboard → Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=""

