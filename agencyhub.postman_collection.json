    {
      "name": "Auth: Verify Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const response = pm.response.json();",
              "if (response.accessToken) {",
              "  pm.environment.set('access_token', response.accessToken);",
              "  console.log('Saved accessToken to environment variable access_token');",
              "} else {",
              "  console.log('No accessToken found in response');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"abdullahdevdesign@gmail.com\",\n  \"otp\": \"123456\",\n  \"passphrase\": \"agency-secure-vault-2026\",\n  \"userId\": \"owner-001\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/verify-login",
          "host": ["{{base_url}}"],
          "path": ["api","auth","verify-login"]
        }
      }
